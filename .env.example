# GitHub API Configuration
# Get your token at: https://github.com/settings/tokens
# Needed for commit tracking API endpoint
GITHUB_TOKEN=your_github_personal_access_token_here

# GitHub Repository Configuration
# Public repository for community feedback and discussions
NEXT_PUBLIC_FEEDBACK_REPO_URL=https://github.com/youbuildit/youbuildit-feedback
# Public repository for code examples and templates
NEXT_PUBLIC_CODE_REPO_URL=https://github.com/youbuildit/youbuildit-examples

# Node Environment (automatically set by Next.js)
# NODE_ENV=development

# Application URL (automatically determined in production)
# Used for API calls and redirects
# NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Database Configuration
# Stores challenge content and solutions
# For development, you can use SQLite
PRISMA_DATABASE_URL="file:./prisma/dev.db"
# For production, use a proper database like PostgreSQL
